# ===========================================================================
# Fleet Inventory Dashboard — environment for docker compose.
# Copy to .env (cp .env.example .env) and replace every placeholder.
# Generate strong random values, e.g.:  openssl rand -hex 32
# ===========================================================================

# --- PostgreSQL (used by the db service and to build DATABASE_URL) ---
POSTGRES_USER=fleet
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=fleet

# --- App secrets (required) ---
# Signs session cookies.
SESSION_SECRET=change-me-openssl-rand-hex-32
# Bearer token Windows reporter agents use to POST /api/report.
INGEST_TOKEN=change-me-openssl-rand-hex-32

# --- Initial admin account (seeded on first boot if no users exist) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-admin-password

# --- Networking ---
# Host port NPM should forward to. The app listens on 8080 inside the container.
APP_PORT=8080

# --- Cookie policy (sane defaults for a single-origin deploy behind NPM/TLS) ---
# Set COOKIE_SECURE=false ONLY for non-HTTPS local testing.
COOKIE_SAMESITE=lax
COOKIE_SECURE=true

# --- Optional ---
# Keep false in production so the fleet starts empty (no demo machines).
SEED_SAMPLE_DATA=false
# Comma-separated full origins (https://host) — only if dashboard/API are split.
ALLOWED_ORIGINS=
